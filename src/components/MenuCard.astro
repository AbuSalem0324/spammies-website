---
import type { MenuItem } from "../lib/content";

interface Props {
  item: MenuItem;
}

const { item } = Astro.props;
const price = item.price.startsWith("£") ? item.price : `£${item.price}`;
---

<article
  class="menu-card group overflow-hidden rounded-xl border border-navy/10 bg-white"
>
  <div class="relative aspect-[4/3] overflow-hidden bg-navy/5">
    <img
      src={item.image}
      alt={item.name}
      loading="lazy"
      class="h-full w-full object-cover"
      onerror="this.src='/images/menu/fallback.jpg'; this.onerror=null;"
    />
    <span
      class="absolute bottom-3 right-3 rounded-full border border-gold/40 bg-navy px-3 py-1 font-display text-sm font-semibold tabular-nums text-gold"
      >{price}</span
    >
  </div>
  <div class="p-4 sm:p-5">
    <h3 class="font-display text-lg font-semibold text-navy">{item.name}</h3>
    {
      item.description && (
        <p class="mt-1.5 text-sm leading-relaxed text-muted">{item.description}</p>
      )
    }
  </div>
</article>
